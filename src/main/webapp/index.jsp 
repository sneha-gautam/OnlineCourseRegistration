<%@ page language="java" contentType="text/html; charset=UTF-8" %>
<!DOCTYPE html>
<html>
<head>
<title>Smart Course Portal</title>

<style>

body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    height: 100vh;
    overflow: hidden;
    background: linear-gradient(-45deg, #0f2027, #203a43, #2c5364, #1c3b52);
    background-size: 400% 400%;
    animation: gradientMove 10s ease infinite;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* 🌊 animated gradient */
@keyframes gradientMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

/* ✨ floating glow circles */
.circle {
    position: absolute;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    animation: float 6s infinite ease-in-out;
}

.circle1 {
    width: 200px;
    height: 200px;
    top: 10%;
    left: 10%;
}

.circle2 {
    width: 300px;
    height: 300px;
    bottom: 10%;
    right: 10%;
    animation-delay: 2s;
}

@keyframes float {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
}

/* CONTENT */
.container {
    text-align: center;
    color: white;
    z-index: 1;
}

/* TITLE */
.title {
    font-size: 42px;
    font-weight: bold;
    letter-spacing: 1px;
}

/* SUBTITLE */
.subtitle {
    font-size: 16px;
    color: #ccc;
    margin: 10px 0 30px;
}

/* BUTTONS */
.btn {
    padding: 12px 28px;
    margin: 10px;
    border-radius: 30px;
    font-size: 16px;
    text-decoration: none;
    display: inline-block;
    transition: 0.3s;
}

/* LOGIN BUTTON */
.login-btn {
    background: linear-gradient(45deg, #4CAF50, #2ecc71);
    color: white;
}

/* REGISTER BUTTON */
.register-btn {
    background: white;
    color: #333;
}

/* HOVER EFFECT */
.btn:hover {
    transform: scale(1.08);
    box-shadow: 0 5px 15px rgba(0,0,0,0.3);
}

</style>
</head>

<body>

<!-- floating elements -->
<div class="circle circle1"></div>
<div class="circle circle2"></div>

<div class="container">

    <div class="title">Smart Course Portal</div>
    <div class="subtitle">Upgrade your skills with modern tech courses</div>

    <a href="login.jsp" class="btn login-btn">Login</a>
    <a href="register.jsp" class="btn register-btn">Register</a>

</div>

</body>
</html>